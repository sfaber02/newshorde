# Copy to .env and adjust. All values optional; sane defaults apply.

# Port the HTTP server listens on
PORT=8787

# Where the SQLite file lives
DATA_DIR=./data

# How often to poll all sources, in minutes
POLL_INTERVAL_MIN=10

# Contact string sent as User-Agent to api.weather.gov (they request one).
# Use your email or app URL.
NWS_CONTACT=newshorde (you@example.com)

# Admin auth. Set ADMIN_PASSWORD to gate /admin (and the admin APIs) with a
# browser password prompt (HTTP Basic). Username is ignored — password only.
# Leave blank to leave admin open (e.g. when gating with Cloudflare Access instead).
ADMIN_PASSWORD=

# Optional: a separate token value accepted via ?token= or the X-Admin-Token
# header for CLI/scripts. Defaults to ADMIN_PASSWORD if left blank.
ADMIN_TOKEN=
