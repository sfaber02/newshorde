# Copy to .env and adjust. All values optional; sane defaults apply.

# Port the HTTP server listens on
PORT=8787

# Where the SQLite file lives
DATA_DIR=./data

# How often to poll all sources, in minutes
POLL_INTERVAL_MIN=10

# Contact string sent as User-Agent to api.weather.gov (they request one).
# Use your email or app URL.
NWS_CONTACT=newshorde (you@example.com)

# Local admin fallback token. If set, requests to /admin and admin APIs must
# present it as `?token=...` or `X-Admin-Token` header. In production the admin
# path is gated by Cloudflare Access at the tunnel edge instead; leave blank there.
ADMIN_TOKEN=
